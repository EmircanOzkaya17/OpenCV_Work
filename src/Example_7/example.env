# ── File Paths ──────────────────────────────────────────────
INPUT_IMAGE_PATH="C:/your/path/to/image.jpg"
OUTPUT_IMAGE_PATH="C:/your/path/to/results"

# ── HSV Green/Yellow Mask Parameters ────────────────────────
# H channel: 25 → yellowish start, 85 → end of green range
HSV_H_MIN=25
HSV_H_MAX=85
# S channel: lower bound to filter out marble background (S≈0)
HSV_S_MIN=40
HSV_S_MAX=255
# V channel: leaves are darker than kiwis (V avg ~125-152)
# kiwi inner texture has V avg ~157-185 → 110 eliminates leaves from mask
HSV_V_MIN=110
HSV_V_MAX=255

# ── Morphological Operation Parameters ──────────────────────
MORPH_KERNEL_SIZE=5
MORPH_OPEN_ITERATIONS=2
MORPH_CLOSE_ITERATIONS=3
MORPH_ERODE_ITERATIONS=1

# ── Contour Filtering Parameters ────────────────────────────
CONTOUR_MIN_AREA=1000
CONTOUR_MAX_AREA=500000
# Circularity threshold
CONTOUR_CIRCULARITY_THRESHOLD=0.45
# Convexity threshold (for wedge/slice shapes)
CONTOUR_CONVEXITY_THRESHOLD=0.65