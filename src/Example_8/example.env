# ============================================================

# IMAGE PATHS (Use relative paths instead of absolute)

# ============================================================

IMAGE_1_PATH=assets/image_1.jpeg
IMAGE_2_PATH=assets/image_2.jpeg

# ============================================================

# OUTPUT SETTINGS

# ============================================================

RESULTS_DIR=results
MATCHES_OUTPUT_NAME=orb_matches.jpg
KEYPOINTS_1_OUTPUT_NAME=keypoints_view1.jpg
KEYPOINTS_2_OUTPUT_NAME=keypoints_view2.jpg

# ============================================================

# ORB PARAMETERS

# ============================================================

ORB_N_FEATURES=1000
ORB_SCALE_FACTOR=1.2
ORB_N_LEVELS=8
ORB_EDGE_THRESHOLD=31
ORB_PATCH_SIZE=31
ORB_FAST_THRESHOLD=20

# ============================================================

# BFMatcher PARAMETERS

# ============================================================

BF_NORM_TYPE=NORM_HAMMING
BF_CROSS_CHECK=True
MATCHES_TO_DRAW=50
